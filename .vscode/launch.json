{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Remote Attach",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "preLaunchTask": "Cleanup",
      "postDebugTask": "Cleanup",
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/src/UpdateWeeklyResults/src",
          "remoteRoot": "/var/task"
        }
      ]
    }
  ]
}
