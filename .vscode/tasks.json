{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sam build",
      "type": "shell",
      "command": "/Users/ccs/Library/Python/3.9/bin/sam",
      "args": [
        "build",
        "--template-file",
        "${workspaceFolder}/min.yaml",
        "UpdateWeeklyResultsPython"
      ],
      "problemMatcher": []
    },
    {
      "label": "Debug UpdateWeeklyResults",
      "type": "shell",
      "command": "/Users/ccs/Library/Python/3.9/bin/sam local invoke -t ${workspaceFolder}/.aws-sam/build/template.yaml UpdateWeeklyResultsPython --event ${workspaceFolder}/events/updateWeeklyResults.json --debugger-path ${workspaceFolder}/.debugger --debug-args '/tmp/lambci_debug_files/debugpy --listen 0.0.0.0:5678 --wait-for-client' -d 5678 --container-host-interface 0.0.0.0",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(x)(\\b)(x)$",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building image",
          "endsPattern": "Debugging will proceed"
        }
      }
    },
    {
      "label": "Cleanup",
      "type": "shell",
      "command": "docker rm -f $(docker ps -aq --filter 'label=com.amazonaws.sam.local=true') 2>/dev/null || true",
      "problemMatcher": []
    }
  ]
}
